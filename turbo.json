{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**"]
    },
    "@belucha/shop#build": {
      "dependsOn": [],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "@belucha/sellercentral#build": {
      "dependsOn": [],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "medusa-backend#dev": {
      "cache": false,
      "persistent": false,
      "dependsOn": [],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "clean": {
      "cache": false
    }
  }
}
