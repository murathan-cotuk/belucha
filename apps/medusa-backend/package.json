{
  "name": "medusa-backend",
  "version": "1.0.0",
  "main": "medusa-config.js",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "build": "medusa build || echo 'Build skipped (TypeScript files compiled at runtime)'",
    "db:setup": "node scripts/write-env-from-process.js && medusa db:setup --no-interactive",
    "db:migrate": "node scripts/write-env-from-process.js && medusa db:migrate --skip-links",
    "run-migrations": "node scripts/run-migrations.js"
  },
  "keywords": ["medusa", "ecommerce", "api", "mock"],
  "author": "",
  "license": "ISC",
  "description": "Medusa-compatible mock backend (bridge). In-memory API for development/testing. NOT production-ready. Real Medusa v2 integration pending.",
  "dependencies": {
    "@medusajs/admin": "^7.1.18",
    "@medusajs/admin-ui": "^2.1.18",
    "@medusajs/auth-emailpass": "^2.0.0",
    "@medusajs/cli": "^2.13.1",
    "@medusajs/file-local": "^2.0.0",
    "@medusajs/fulfillment-manual": "^2.0.0",
    "@medusajs/framework": "^2.13.1",
    "@medusajs/medusa": "^2.13.1",
    "@medusajs/notification-local": "^2.0.0",
    "ajv": "^8.17.1",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "medusa": "^0.0.3",
    "ts-node": "^10.9.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {}
}
