# Medusa Backend
NODE_ENV=development
PORT=9000

# Database (PostgreSQL - Production için)
DATABASE_URL=postgres://user:password@localhost:5432/medusa-db

# Redis (Session & Cache)
REDIS_URL=redis://localhost:6379

# Stripe
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin CORS
ADMIN_CORS=http://localhost:7001,http://localhost:3002

# Store CORS  
STORE_CORS=http://localhost:3000

# JWT Secret
JWT_SECRET=medusaSecretKey123

# Cookie Secret
COOKIE_SECRET=medusaCookieSecret123