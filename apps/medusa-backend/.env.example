# Medusa v2 Backend - Örnek env (kopyalayıp .env.local yapın)
# Yerel geliştirme için: Render'daki PostgreSQL'i kullanacaksanız,
# Render Dashboard → belucha-medusa-db → External Database URL'i kopyalayıp
# aşağıdaki DATABASE_URL olarak yapıştırın (localhost yerine).

# Database
# Yerel PostgreSQL: postgresql://user:password@localhost:5432/medusa
# Render (External): Render dashboard'dan "External Database URL" kopyalayın
DATABASE_URL=postgresql://medusa_user:XXX@dpg-XXXXX.frankfurt-postgres.render.com/medusa_seoj

# Server
PORT=9000
HOST=0.0.0.0
NODE_ENV=development

# CORS (yerel frontend adresleri)
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:3002
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Secrets (production'da mutlaka değiştir)
JWT_SECRET=medusa-jwt-secret-change-in-production
COOKIE_SECRET=medusa-cookie-secret-change-in-production
SERVER_URL=http://localhost:9000
